{
  "name": "incident-portal",
  "version": "0.1.0",
  "private": true,
  "description": "Portail de gestion des incidents — ETS MARCEL RECORDZ",
  "author": {
    "name": "ETS MARCEL RECORDZ",
    "email": "support@marcelrecordz.cm"
  },
  "main": "electron-main.js",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "electron": "electron .",
    "electron:dev": "set NODE_ENV=development&& electron .",
    "electron:prod": "npm run build && set NODE_ENV=production&& electron .",
    "electron:dist": "npm run build && electron-builder",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "prisma db seed",
    "setup": "prisma migrate deploy && prisma db seed"
  },
  "build": {
    "appId": "com.marcelrecordz.incidentportal",
    "productName": "Incident Portal",
    "copyright": "Copyright © 2026 ETS MARCEL RECORDZ",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-main.js",
      "package.json",
      ".next/**/*",
      "public/**/*",
      "app/**/*",
      "next.config.ts",
      "next-env.d.ts"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Incident Portal"
    }
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^6.0.0",
    "@tanstack/react-query": "^5.0.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "country-state-city": "^3.2.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^1.8.0",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.28",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.48.0",
    "react-hot-toast": "^2.4.0",
    "recharts": "^2.10.0",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "electron": "^41.3.0",
    "electron-builder": "^24.13.3",
    "prisma": "^6.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
